# SEO Keyword Tracker — Environment Variables
# Copy this file to .env and fill in the values.

# Turso database (required for keyword storage)
# Create a free database at https://turso.tech
DATABASE_URL=libsql://your-db-name-your-org.turso.io
LIBSQL_TOKEN=your-turso-auth-token-here

# Z.AI API key (required for AI keyword generation)
# Get a free key at https://z.ai
ZAI_API_KEY=your-zai-api-key-here

# Google OAuth 2.0 (required for Search Console + Analytics integration)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://seo-keyword-tracker-gules.vercel.app/api/auth/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
